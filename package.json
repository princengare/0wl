{
  "name": "0wl",
  "version": "0.1.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "Local-first Firefox WebExtension for website usage tracking and blocking.",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch --preserveWatchOutput",
    "build": "npm run typecheck && vite build",
    "build:watch": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "firefox": "web-ext run --source-dir dist",
    "firefox:dev": "node scripts/firefox-dev.mjs",
    "web-ext:lint": "web-ext lint --source-dir dist",
    "package": "web-ext build --source-dir dist --artifacts-dir web-ext-artifacts --overwrite-dest",
    "release:check": "node scripts/verify-release.mjs",
    "release:prepare": "node scripts/prepare-release.mjs",
    "updates:manifest": "node scripts/create-update-manifest.mjs",
    "sign:firefox": "node scripts/sign-firefox.mjs"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tldts": "^6.1.70",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testing-library/react": "^16.1.0",
    "@types/firefox-webext-browser": "^120.0.4",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vitest": "^4.1.10",
    "web-ext": "^10.4.0"
  }
}
